<UserControl x:Class="Soundboard.Views.ButtonGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Soundboard.Views"
             xmlns:converter="clr-namespace:Soundboard.Common.Converters;assembly=Soundboard.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Soundboard.Common;component/Styles/AddButtonStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <converter:InverseBooleanToVisibility x:Key="InverseBooleanToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="5,2,5,2">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding SoundButtons}" 
                      x:Name="SoundButtonsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding GridColumns}" 
                                 HorizontalAlignment="Left" 
                                 VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SoundButtonBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0"
                                    Style="{StaticResource SoundButtonStyle}"
                                    Content="{Binding DisplayText}"
                                    Command="{Binding Command}"/>

                                <TextBlock Grid.Row="1"
                                   Text="{Binding KeyBindingDisplay}"
                                   FontSize="10"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="2"
                                   Visibility="{Binding IsAddButton, Converter={StaticResource InverseBooleanToVisibility}}"
                                   Cursor="Hand">
                                    <TextBlock.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                            Command="{Binding DataContext.SetKeyBindingCommand, 
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
